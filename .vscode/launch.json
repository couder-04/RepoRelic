{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceRoot}/extension"
            ],
            "outFiles": [
                "${workspaceRoot}/extension/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile"
        }
    ]
}
