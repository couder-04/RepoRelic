{
  "name": "reporelic",
  "displayName": "RepoRelic",
  "description": "AI-powered Python repository analysis, autonomous test generation, execution diagnostics, and intelligent reporting.",
  "version": "1.0.7",
  "publisher": "YAPrepo",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/couder-04/RepoRelic"
  },
  "homepage": "https://github.com/couder-04/RepoRelic",
  "bugs": {
    "url": "https://github.com/couder-04/RepoRelic/issues"
  },
  "keywords": [
    "ai",
    "python",
    "testing",
    "llm",
    "analysis",
    "static-analysis",
    "code-analysis",
    "test-generation",
    "dependency-graph",
    "knowledge-graph",
    "diagnostics",
    "automation",
    "developer-tools",
    "pytest",
    "gemini",
    "openai"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Linters",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onCommand:reporelic.analyze",
    "onCommand:reporelic.openSetup",
    "workspaceContains:**/*.py"
  ],
  "main": "./out/extension.js",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "preview": false,
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "reporelic.analyze",
        "title": "Analyze with RepoRelic",
        "category": "RepoRelic",
        "icon": "$(search-view-icon)"
      },
      {
        "command": "reporelic.openSetup",
        "title": "RepoRelic: Open Setup Wizard",
        "category": "RepoRelic",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "reporelic.analyze",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "reporelic.analyze",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "reporelic.openSetup"
        }
      ]
    },
    "configuration": {
      "title": "RepoRelic",
      "properties": {
        "reporelic.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python executable used to run the RepoRelic engine."
        },
        "reporelic.repoPath": {
          "type": "string",
          "default": "",
          "description": "Full path to the local RepoRelic repository containing the engine folder."
        },
        "reporelic.llmProvider": {
          "type": "string",
          "enum": [
            "openai",
            "gemini"
          ],
          "default": "openai",
          "markdownDescription": "LLM provider used for autonomous test generation and failure diagnosis."
        },
        "reporelic.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for OpenAI-compatible providers including OpenAI, DeepSeek, GPT-OSS gateways, and local OpenAI-compatible inference servers."
        },
        "reporelic.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "markdownDescription": "Base URL for OpenAI-compatible APIs. Example: `https://api.deepseek.com/v1`"
        },
        "reporelic.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Google Gemini API key from https://aistudio.google.com"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
